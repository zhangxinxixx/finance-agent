*.py[cod]
*.egg-info/
.eggs/
*.egg
dist/
build/
*.whl
.venv/
venv/

# Environment
.env
.env.local
.env.*.local
.local/
*.pem
*.key
*.p12
*.pfx

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.orig
*.rej
