# ============================================================
# finance-agent 环境变量模板
# 复制为 .env 后填写真实值，.env 已在 .gitignore 中排除
# ============================================================

# --- 宏观数据 ---
FRED_API_KEY=

# --- 市场数据 ---
TWELVE_DATA_API_KEY=

# --- 数据库 ---
DATABASE_URL=postgresql://finance_agent:<password>@127.0.0.1:55432/finance_agent
DATABASE_PASSWORD=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
OPENAI_API_KEY=

# --- 通知/推送（P1 增强） ---
FEISHU_WEBHOOK_URL=
FEISHU_BOT_SECRET=

# --- 飞书金十群消息拉取（可选，P0 news ingest） ---
# 推荐为业务采集单独创建 app/bot，不复用远程 Codex bridge bot。
FEISHU_NEWS_APP_ID=
FEISHU_NEWS_APP_SECRET=
FEISHU_JIN10_CHAT_ID=
