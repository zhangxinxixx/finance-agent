# ============================================================
# finance-agent 环境变量模板
# 复制为 .env 后填写真实值，.env 已在 .gitignore 中排除
# ============================================================

# --- 宏观数据 ---
FRED_API_KEY=
FINANCE_AGENT_OPENBB_FALLBACK_TIMEOUT_SECONDS=30
FINANCE_AGENT_FRED_REQUEST_TIMEOUT_SECONDS=10
FINANCE_AGENT_FRED_MAX_WORKERS=6

# --- 市场数据 ---
TWELVE_DATA_API_KEY=

# --- 数据库 ---
DATABASE_URL=postgresql://finance_agent:<password>@127.0.0.1:55432/finance_agent
DATABASE_PASSWORD=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM ---
OPENAI_API_KEY=
JOJOCODE_API_KEY=
JOJOCODE_BASE_URL=https://max.jojocode.com/v1
LLM_JOJOCODE_MODEL=gpt-5.6-sol

# --- 新闻 freshness / 联网兜底 ---
NEWS_FRESHNESS_MAX_AGE_HOURS=6
# 默认使用 HTTPS_PROXY/http_proxy 做一次失败 query-group 重试；仅在确认直连可用时开启 direct fallback。
NEWS_HTTP_PROXY=
NEWS_DIRECT_FALLBACK_ENABLED=false
# 仅当配置的 Responses 兼容 provider 确实支持 web_search tool 时开启。
NEWS_WEB_SEARCH_FALLBACK_ENABLED=true
NEWS_WEB_SEARCH_LLM_PROVIDER=jojocode
NEWS_WEB_SEARCH_LLM_MODEL=gpt-5.6-sol
NEWS_WEB_SEARCH_TIMEOUT_SECONDS=120

# --- LLM 审计读取权限（必填后才启用 /api/llm/audits） ---
FINANCE_AGENT_AUDIT_READER_TOKEN=

# --- Analysis Memory 人工复核写权限（未配置时 POST review 保持关闭） ---
FINANCE_AGENT_ANALYSIS_MEMORY_WRITE_TOKEN=

# --- 通知/推送（P1 增强） ---
FEISHU_WEBHOOK_URL=
FEISHU_BOT_SECRET=

# --- 飞书金十群消息拉取（可选，P0 news ingest） ---
# 推荐为业务采集单独创建 app/bot，不复用其他系统的机器人凭证。
FEISHU_NEWS_APP_ID=
FEISHU_NEWS_APP_SECRET=
FEISHU_JIN10_CHAT_ID=
