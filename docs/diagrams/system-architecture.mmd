flowchart LR
  Frontend["前端主线<br/>Vite React TypeScript"] --> API["FastAPI<br/>routes + services"]
  API --> DB[("PostgreSQL / SQLite-compatible models")]
  API --> Storage["storage artifacts"]
  API --> Launch["Dagster GraphQL launch"]

  Schedule["Dagster schedules"] --> Job["premarket_job"]
  Launch --> Job
  Job --> Macro["macro pipeline"]
  Job --> CME["CME pipeline"]
  Job --> News["news pipeline"]
  Macro --> Snapshot["analysis snapshot"]
  CME --> Snapshot
  News --> Snapshot
  Snapshot --> Gate["source readiness gate"]
  Gate --> Analysis["composite analysis<br/>agents + fact review + quality gate"]
  Analysis --> Renderer["renderer / output"]
  Renderer --> Storage
  Analysis --> DB

  Collectors["collectors"] --> Raw["storage/raw"]
  Raw --> Parsers["parsers"]
  Parsers --> Parsed["storage/parsed"]
  Parsed --> Features["features"]
  Features --> FeatureStore["storage/features"]
  FeatureStore --> Snapshot
