flowchart TD
  Trigger["API trigger 或 weekday schedule"] --> Preflight["active run + source readiness preflight"]
  Preflight --> Init["premarket_task_run_init"]
  Init --> Macro["macro: collect -> feature -> render"]
  Init --> CME["CME: download -> parse -> ingest -> option wall"]
  Init --> News["news: collect -> feature -> brief"]
  Macro --> Merge["merge_analysis_snapshot"]
  CME --> Merge
  News --> Merge
  Merge --> Readiness["fail-closed readiness gate"]
  Readiness --> Domain["domain agents"]
  Domain --> Coordinator["coordinator"]
  Coordinator --> Review["fact review"]
  Review --> Quality["quality gate / fallback"]
  Quality -->|PASS| Accepted["accepted final report + strategy card"]
  Quality -->|blocked / needs review| Observe["observation report + card"]
  Accepted --> Complete["TaskRun complete + artifacts"]
  Observe --> Complete
  Init -. failure hook .-> Failed["TaskRun failed"]
