flowchart LR
  Inputs["snapshots + Agent outputs + source refs"] --> Gate["Quality Gate"]
  Gate -->|accepted| Accepted["accepted report identity"]
  Gate -->|not accepted| Observe["observation identity"]
  Accepted --> Source["source_md when available"]
  Accepted --> Analysis["analysis_md"]
  Accepted --> Structured["structured_json"]
  Accepted --> Visual["visual_html when available"]
  Observe --> ObservationArtifacts["observation report/card"]
  Source --> Registry["ReportItem + ReportArtifact"]
  Analysis --> Registry
  Structured --> Registry
  Visual --> Registry
  Registry --> Detail["/reports/:reportId"]
  ObservationArtifacts --> Review["diagnostics / review only"]
