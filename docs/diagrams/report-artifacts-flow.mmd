flowchart LR
  RawAssets["原始材料<br/>图片 / PDF / HTML / JSON"] --> Parse["内容提取<br/>OCR / VLM / parser / 结构化解析"]
  Parse --> SourceMd["原文产物<br/>source.md 或 source artifact"]
  Parse --> Features["特征快照<br/>feature snapshot"]
  Features --> AnalysisMd["分析正文<br/>analysis.md<br/>LLM 或确定性分析"]
  Features --> Structured["结构化报告<br/>report_structured.json"]
  AnalysisMd --> Visual["可视化报告<br/>visual.html"]
  Structured --> Visual
  SourceMd --> ReportItem["报告记录<br/>ReportItem"]
  AnalysisMd --> ReportArtifact["报告产物<br/>ReportArtifact"]
  Structured --> ReportArtifact
  Visual --> ReportArtifact
  ReportArtifact --> Detail["报告详情页<br/>/reports/:reportId"]
